# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── PyTorch / ML ──────────────────────────────────────────────────────────────
*.pt
*.pth
*.ckpt
*.pkl
*.h5
runs/
lightning_logs/
wandb/
mlruns/

# ── Data ──────────────────────────────────────────────────────────────────────
# Keep folder structure but ignore actual dataset files
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# ── Outputs ───────────────────────────────────────────────────────────────────
outputs/*
!outputs/.gitkeep

# ── Common image/video formats (large files) ──────────────────────────────────
*.jpg
*.jpeg
*.png
*.bmp
*.tiff
*.tif
*.mp4
*.avi
*.mov

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Secrets / config ──────────────────────────────────────────────────────────
.env
*.env
config_local.py
